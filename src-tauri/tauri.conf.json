{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XLauchez",
  "version": "0.1.0",
  "identifier": "dev.xlauchez.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "XLauchez",
        "width": 960,
        "height": 640,
        "minWidth": 800,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
